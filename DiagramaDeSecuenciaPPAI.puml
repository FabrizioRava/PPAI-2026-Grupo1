
@startuml PPAI
autonumber "<b>00-"
skinparam style strictuml
skinparam ranking as actores

skinparam sequence {
    ParticipantBackgroundColor #EBF3F9
    ParticipantBorderColor #336699
    ParticipantFontName Arial
    ParticipantFontSize 11
    ActorBackgroundColor #FFE6CC
    ActorBorderColor #D79B00
}

skinparam entityBackgroundColor #F5F5F5
skinparam entityBorderColor #666666
skinparam controlBackgroundColor #E2EFDA
skinparam controlBorderColor #375623
skinparam boundaryBackgroundColor #FFF2CC
skinparam boundaryBorderColor #7F6000

skinparam sequenceParticipant {
    roundcorner 100
}

title Diagrama de Secuencia: CU 36 - Consultar seguimiento de bolsines

actor ":EncargadoBolsines" as EB
boundary ":InterfazSeguimiento" as UI <<boundary>>
control ":GestorSeguimientoBolsines" as Ctrl <<control>>

' Entidades del sistema
entity "activa:Sesion" as Sesion <<entity>>
entity "logueado:Usuario" as User <<entity>>
entity "logueado:Empleado" as EmpLog <<entity>>
entity ":ComisionMedica" as CMOrig <<entity>>
entity ":Bolsin" as BolsinAux <<entity>>
entity "actual:CambioEstadoBolsin" as CambioEstado <<entity>>
entity "actual:Estado" as Estado <<entity>>
entity "P:Precinto" as Precinto <<entity>>

' Boundaries de Fabricación Pura para Actores Externos
boundary ":IAdaptadorGPS" as AdaptadorGPS <<boundary>>
boundary ":IAdaptadorMaps" as AdaptadorMaps <<boundary>>

' Actores Externos
actor ":GPSTracker" as GPS
actor ":ServidorGoogleMaps" as Maps

' Entidades de la segunda fase del flujo
entity "elegida:Bolsin" as Bolsin <<entity>> #FCE4D6
entity "cmBolsinSeleccionado:ComisionMedica" as CMDest <<entity>>
entity ":Empleado" as EmpCorp <<entity>>
participant "CU 31: Notificar ubicación de bolsín" as CU_Notif

EB -> UI : seleccionarConsultarUbicacion()
activate UI

UI -> UI : habilitarVentana()
activate UI
deactivate UI

UI -> Ctrl : consultarSeguimientoBolsines()
activate Ctrl

Ctrl -> Ctrl : obtenerUsuarioLogueado()
activate Ctrl
    Ctrl -> Sesion : getUsuarioSesion()
    activate Sesion
        Sesion -> User : getEmpleado()
        activate User
            User -> EmpLog : getCM()
            activate EmpLog
                EmpLog -> EmpLog : getCM()
                activate EmpLog
                deactivate EmpLog
            deactivate EmpLog
        deactivate User
    deactivate Sesion
deactivate Ctrl

Ctrl -> UI : mostrarCMUsuario()

Ctrl -> Ctrl : buscarBolsinesEnviados()
activate Ctrl
    Ctrl -> CMOrig : buscarBolsinesEnviados()
    activate CMOrig
        loop [BúsquedaBolsines] [Mientras haya bolsines]
            CMOrig -> BolsinAux : verificarCorrespondencia()
            activate BolsinAux
                BolsinAux -> BolsinAux : esTuCMOrigen()
                activate BolsinAux
                deactivate BolsinAux
                
                BolsinAux -> CambioEstado : sosActual()
                activate CambioEstado
                deactivate CambioEstado
                
                BolsinAux -> CambioEstado : sosEnviado()
                activate CambioEstado
                    CambioEstado -> Estado : esEnviado()
                    activate Estado
                    deactivate Estado
                deactivate CambioEstado
            deactivate BolsinAux
        end
    deactivate CMOrig
deactivate Ctrl

' Fase de recolección de datos previos antes de consumir el GPS Tracker e incluir Nro de Precinto
Ctrl -> Ctrl : obtenerDatosParaLocalizacionYFiltro()
activate Ctrl
    Ctrl -> CMOrig : getApiKey()
    activate CMOrig
    deactivate CMOrig
    
    Ctrl -> CMOrig : getNroCM()
    activate CMOrig
    deactivate CMOrig
    
    loop [Para cada bolsín enviado detectado]
        Ctrl -> BolsinAux : getIdBolsin()
        activate BolsinAux
        deactivate BolsinAux
        
        Ctrl -> BolsinAux : getNroPrecinto()
        activate BolsinAux
            BolsinAux -> Precinto : getNroPrecinto()
            activate Precinto
            deactivate Precinto
        deactivate BolsinAux
    end
deactivate Ctrl

' Consulta al GPS a través de clase Frontera (Desacoplado)
Ctrl -> Ctrl : consultarUbicacionesGPS()
activate Ctrl
    Ctrl -> AdaptadorGPS : consultarLocalizacion()
    activate AdaptadorGPS
        AdaptadorGPS -> GPS : *getBolsinLocation()
        activate GPS
        deactivate GPS
    deactivate AdaptadorGPS
deactivate Ctrl

' Generación del mapa a través de clase Frontera (Desacoplado)
Ctrl -> Ctrl : generarMapa()
activate Ctrl
    Ctrl -> AdaptadorMaps : solicitarRenderizadoMapa()
    activate AdaptadorMaps
        AdaptadorMaps -> Maps : obtenerMapaConPosiciones()
        activate Maps
        deactivate Maps
    deactivate AdaptadorMaps
deactivate Ctrl

Ctrl -> UI : mostrarMapaYFiltros()
deactivate Ctrl

EB -> UI : seleccionarBolsinDelMapa()

UI -> Ctrl : tomarSeleccionBolsin()
activate Ctrl

Ctrl -> Ctrl : validarEnvioCorreoGCM()
activate Ctrl
deactivate Ctrl

Ctrl -> UI : solicitarConfirmacionEnvio()
deactivate Ctrl

EB -> UI : confirmarEnvioCorreo()

UI -> Ctrl : procesarEnvioNotificacion()
activate Ctrl

Ctrl -> Ctrl : obtenerComisionDestino()
activate Ctrl
    Ctrl -> Bolsin : identificarComisionDestino()
    activate Bolsin
        Bolsin -> CMDest : obtenerCMDestino()
        activate CMDest
            CMDest -> CMDest : getNombre()
            activate CMDest
            deactivate CMDest
        deactivate CMDest
    deactivate Bolsin
deactivate Ctrl

Ctrl -> Ctrl : buscarEmailGCM()
activate Ctrl
    Ctrl -> CMDest : buscarEmailGCM()
    activate CMDest
        loop [BúsquedaEmails] [Mientras haya empleados]
            CMDest -> EmpCorp : esTuCM()
            activate EmpCorp
            deactivate EmpCorp
            CMDest -> EmpCorp : sosGCM()
            activate EmpCorp
            deactivate EmpCorp
            CMDest -> EmpCorp : getEmail()
            activate EmpCorp
            deactivate EmpCorp
        end
    deactivate CMDest
deactivate Ctrl

Ctrl -> Ctrl : llamarCUNotificarUbicacion()
activate Ctrl
deactivate Ctrl

Ctrl -> CU_Notif : «include»
activate CU_Notif
deactivate CU_Notif

Ctrl -> UI : informarEjecucionExitosa()
deactivate Ctrl

UI -> EB : mostrarMensajeExito()
deactivate UI

Ctrl -> Ctrl : finCU()

@enduml