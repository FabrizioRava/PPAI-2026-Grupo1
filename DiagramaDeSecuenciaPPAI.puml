@startuml test
autonumber "<b>00-"
skinparam style strictuml
skinparam ranking as actores

' Configuración de colores basados en la foto de los profesores (Celeste: #C5EBEF, Naranja: #FF5B00)
skinparam sequence {
    LifeLineBackgroundColor #C5EBEF
    LifeLineBorderColor #333333
    
    ParticipantBackgroundColor #C5EBEF
    ParticipantBorderColor #333333
    ParticipantFontName Arial
    ParticipantFontSize 11
    ActorBackgroundColor #FFE6CC
    ActorBorderColor #D79B00
}

' Colores específicos para los estereotipos y entidades según la imagen
skinparam entityBackgroundColor #C5EBEF
skinparam entityBorderColor #333333
skinparam controlBackgroundColor #C5EBEF
skinparam controlBorderColor #333333
skinparam boundaryBackgroundColor #C5EBEF
skinparam boundaryBorderColor #333333

skinparam sequenceParticipant {
    roundcorner 100
}

title Diagrama de Secuencia: CU 36 - Consultar seguimiento de bolsines

actor "<b><u>:Encargado Bolsin" as EB
boundary "<b><u>:PantSegBolsines" as P
control "<b><u>:GestorSegBolsines" as G
entity "<b><u>A:Sesion" as S
entity "<b><u>L:Usuario" as U
entity "<b><u>L:Empleado" as E
entity "<b><u>G:Empleado" as GE

' Resaltados en Naranja según la foto de la cátedra
entity "<b><u>:Bolsin" as B #FF5B00
entity "<b><u>S:Bolsin" as Bs 
entity "<b><u>:Empleado" as Em #FF5B00
entity "<b><u>:Comision Medica" as CM
entity "<b><u>:Rol" as R 
entity "<b><u>:CambioDeEstadoBolsin" as cEstB #FF5B00

entity "<b><u>A:CambioDeEstadoBolsin" as estAB
entity "<b><u>A:EstadoBolsin" as estB

' Interfaz clase fabricación pura
boundary "<b><u>GPS Tracker" as GPS
actor "<b><u>GPS Tracker" as GpAc
boundary "<b><u>GoogleMaps" as BGMap
actor "<b><u>GoogleMaps" as GMap
participant "<b><u>CU31" as CU31 <<usecase>>

' 1. EB: opConsultarUbicBolsines()
EB -> P: opConsultarUbicBolsines()
activate P

P -> P: habilitarVentana()
activate P
deactivate P

P -> G: opConsultarUbicBolsines() 
activate G

' 2. Sistema: buscarCMUsuarioLogueado()
G -> G ++ : buscarCMUsuarioLogueado()
deactivate G
    G -> S ++ : buscarCMUsuarioLogueado()
        S -> U ++ : obtenerEmpleado()
            U -> E ++ : obtenerCodigoCM()
                E -> CM ++ : obtenerNombreCM()
                deactivate CM
                E -> CM ++ : obtenerCodigoCM()
                deactivate CM
            deactivate E
        deactivate U
    deactivate S

G -> P: mostrarNombreCM()

' 3. Sistema: buscarBolsinesEnEstadoEnviado() [Adaptado del diagrama de referencia]
G -> G ++ : buscarBolsinesEnEstadoEnviado()
deactivate G
    group Bolsines en estado Enviado [mientras haya bolsines]
        ' Se adaptó la llamada a B para usar sosEnviado() con su cuadradito compacto naranja
        G -> B ++ #FF5B00: sosEnviado()
            ' cEstB es naranja, su activación debe ser naranja
            B -> cEstB ++ #FF5B00: sosActual()
            deactivate cEstB
            ' estAB es celeste
            B -> estAB ++: sosEnviado()
                ' estB es celeste
                estAB -> estB ++: sosEnviado()
                deactivate estB
            deactivate estAB
            ' estAB es celeste
            B -> estAB ++: obtenerFechaHoraInicio()
            deactivate estAB
        deactivate B

        ' Las llamadas a B (naranja) deben tener activaciones naranjas y ser cuadradas
        G -> B ++ #FF5B00: esTuCMDeOrigen()
        deactivate B
        G -> B ++ #FF5B00: obtenerNumeroPrecinto()
        deactivate B
        G -> B ++ #FF5B00: obtenerNumeroBolsin()
        deactivate B
    end

' 4. Sistema: solicitar...
' 5. Sistema: recibe del dispositivo GPS Tracker...
G -> G ++ : buscarDatosLocalizacionBolsin()
deactivate G
    group Bolsines en estado Enviado [mientras haya bolsines enviados]
        G -> B ++ #FF5B00: obtenerDatosLocalizacionBolsin()
            B -> GPS ++: obtenerDatosLocalizacionBolsin()
                GPS -> GpAc ++: obtenerDatosLocalizacionBolsin()
                deactivate GpAc
            deactivate GPS
        deactivate B
        G -> BGMap ++: obtenerUbicacionBolsin()
            BGMap -> GMap ++: obtenerUbicacionBolsin()
            deactivate GMap
        deactivate BGMap
    end

' 6. Sistema: mostrarUbicacionBolsines()
G -> P: mostrarUbicacionBolsines()

' 7. EB: solicitarSeleccionBolsin()
G -> P: solicitarSeleccionBolsin()
deactivate G
deactivate P

' El sistema se apaga acá esperando la interacción del usuario
EB -> P: tomarSeleccionBolsin()
activate P

P -> G: tomarSeleccionBolsin()
activate G

' 8. Sistema: mostrarOpEnviarMail()
G -> P: mostrarOpEnviarMail()
deactivate G
deactivate P

' El sistema se vuelve a apagar esperando que el usuario confirme en la pantalla
EB -> P: tomarConfirmacionEnvioMail()
activate P

P -> G: tomarConfirmacionEnvioMail()
activate G

G -> G ++: obtenerCMDestino()
deactivate G
    G -> Bs ++: obtenerCMDestino()
    deactivate Bs

' 10. Sistema: buscarMailGerente()
G -> G ++: buscarMailGerente()
deactivate G
    group Empleados CM Destino [mientras haya empleados y no se encuentre el gerente del CM destino]
        ' Em es naranja, activación debe ser naranja
        G -> Em ++ #FF5B00: esTuCM()
        deactivate Em
        ' Em es naranja, activación debe ser naranja
        G -> Em ++ #FF5B00: esGerenteCMDestino()
            ' R es celeste
            Em -> R ++: esGerente()
            deactivate R
        deactivate Em
    end

G -> GE ++: obtenerMail()
deactivate GE

G -> G: enviarMailGerente()
activate G
deactivate G

' 11. Sistema: Flecha normal continua para la llamada al caso de uso incluido
G -> CU31: «include» llamarCUNotificacionBolsin()
activate CU31
deactivate CU31

G -> P: mostrarMensajeEnvioMail()

G -> G: finCU()
activate G
deactivate G

deactivate G
deactivate P

@enduml
